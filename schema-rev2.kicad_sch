	(text "CL = (C1 * C2) / (C1 + C2) + Cstray\nC1 = C2 = 2CL + 2Cstray\n\npre CL = 30pF; Cstray = 5pF\n=> C1 = C2 = 70pF\n\nNajbližšia štandardná\nhodnota: 68p"
		(exclude_from_sim no)
		(at 50.292 237.236 0)
