		(uuid "0dc599ef-6f1b-420f-aa89-8eb78aad6209")
	)
	(text_box "POZNÁMKY:\n- Pre pull-up/pull-down rezistory používame hodnoty 10K keďže je to pri 5V logike\nštandard ktorý poskytuje kompromis medzi stratovým prúdom a stabilnou logickou hodnotou.\n- Pre signálové linky používame diódy 1N5819 tam kde úbytok Uf ~ 0,7V nie je problém, inak 1N4148 (menšie rozmery). "
		(exclude_from_sim no)
		(at 246.5984 360.6799 0)
