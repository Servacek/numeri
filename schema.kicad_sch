		(uuid "a77030cc-7947-4485-8159-51fadf31481d")
	)
	(text_box "DIZAJNOVÁ POZNÁMKA:\nDiódy môžu byť použité jednoho typu prípadne len jeden kus,"
		(exclude_from_sim no)
		(at 148.59 92.71 0)
		(size 67.31 5.08)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
			(color 255 223 43 1)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "b464a3a0-d20b-45d8-ac27-c7c5109d425a")
	)
	(text_box "- Bez aktívnej negociácie vieme dostať z chytrých USB-C nabíjačiek maximálne 15W.\n- Pomocou 5K1 pull-up rezistorov na CC1 a CC2 žiadame zdroj o 15W.\n- Celý obvod môže teoreticky brať až do 1A v závislosti od počtu rozsvietených segmentov a konfigurácie.\n- Maximálna kapacita priamo pripojená na VBUS linku je 10uF podľa špecifikácii, treba však rátať s napäťovým skreslením a s feritom."
		(exclude_from_sim no)
		(at 176.53 102.87 0)
		(size 92.71 13.97)
		(margins 0.9525 0.9525 0.9525 0.9525)
